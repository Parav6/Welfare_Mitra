# Welfare Mitra — Environment Configuration Template

# Google Gemini API key (Required for active chat & translation fallbacks)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Bhashini API Configuration (Optional: falls back to Gemini if omitted)
# BHASHINI_USER_ID=your_bhashini_userid_here
# BHASHINI_API_KEY=your_bhashini_apikey_here
# BHASHINI_ULCA_API_KEY=your_ulca_apikey_here
# BHASHINI_PIPELINE_ID=64392f55f603c1520e545bb8

# Local Server Settings
PORT=3000
MOCK_BHASHINI=true
